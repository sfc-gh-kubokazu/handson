{
  "_comment": "Snowflake-managed MCP Server (PAT Bearer) config for Kiro / Cursor / Claude Desktop. Replace placeholders.",
  "_notes": [
    "Kiro has no MCP GUI. Edit ~/.kiro/settings/mcp.json directly.",
    "PAT (Programmatic Access Token) is the supported auth path for mcp-remote based clients.",
    "OAuth fails on these clients because Snowflake-managed MCP server does not expose RFC 7591 Dynamic Client Registration.",
    "Reference: https://community.snowflake.com/s/article/resolving-mcp-server-authentication-errors-cursor-claude",
    "Replace <account_url> with your Snowflake account URL (use hyphens, not underscores).",
    "Replace <YOUR_PAT> with the token_secret returned by ALTER USER ... ADD PROGRAMMATIC ACCESS TOKEN."
  ],
  "mcpServers": {
    "snowflake-braze": {
      "url": "https://<account_url>/api/v2/databases/HANDSON_CORTEX_AGENT/schemas/BRAZE/mcp-servers/BRAZE_MCP_SERVER",
      "headers": {
        "Authorization": "Bearer <YOUR_PAT>"
      },
      "disabled": false,
      "autoApprove": []
    }
  }
}
