# Snowflake-managed MCP Server - Spec Template
#
# Use this YAML inside CREATE MCP SERVER ... FROM SPECIFICATION $$ ... $$;
# Tool types supported:
#   - CORTEX_AGENT_RUN          : Cortex Agent
#   - CORTEX_ANALYST_MESSAGE    : Cortex Analyst (semantic view)
#   - CORTEX_SEARCH_SERVICE_QUERY : Cortex Search
#   - SYSTEM_EXECUTE_SQL        : SQL execution
#   - GENERIC                   : UDF / Stored Procedure

tools:
  - name: "braze-agent"
    type: "CORTEX_AGENT_RUN"
    identifier: "HANDSON_CORTEX_AGENT.BRAZE.BRAZE_AGENT"
    description: "Brazeのメールキャンペーン分析エージェント。送信/開封/クリック/CV/収益を自然言語で分析"
    title: "Braze Agent"

  - name: "braze-campaign-analyst"
    type: "CORTEX_ANALYST_MESSAGE"
    identifier: "HANDSON_CORTEX_AGENT.BRAZE.SEMANTIC_VIEW_BRAZE_CAMPAIGN"
    description: "Brazeメールキャンペーンのセマンティックビュー（直接Analyst呼び出し用）"
    title: "Braze Campaign Analyst"

